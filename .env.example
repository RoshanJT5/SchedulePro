# Example environment variables for PlanSphere
# Copy this to a file named .env and update values for your environment

# SQLAlchemy Database URL. For Docker compose the service name is 'db'.
DATABASE_URL=postgresql+psycopg2://plansphere:plansphere@db:5432/plansphere

# Secret key used to sign JWTs. Change in production.
SECRET_KEY=dev-secret-change-me-please

# JWT algorithm (optional)
JWT_ALGORITHM=HS256

# Access token expiry minutes (optional)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Grok AI API Configuration (Optional - for AI-powered timetable generation)
# Get your key from https://openrouter.ai/
GROK_API_KEY=your-grok-api-key-here
GROK_API_URL=https://api.x.ai/v1/chat/completions
